---
import { getPermalink } from '~/utils/permalinks';
import { getRelatedServicesForPostSlug } from '~/data/services';

export interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
const relatedServices = getRelatedServicesForPostSlug(postSlug);
---

{
  relatedServices.length > 0 ? (
    <section class="mx-auto px-6 sm:px-6 max-w-4xl pb-8 md:pb-12">
      <div class="rounded-3xl border border-slate-700/60 bg-slate-900/40 p-6 md:p-8">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight font-heading mb-3">Need Help With This Issue?</h2>
        <p class="text-muted dark:text-slate-400 mb-6 max-w-2xl">
          These are the closest service pages for this topic. If you are not sure which one fits, start with a
          consultation and we will route you properly.
        </p>
        <div class="grid gap-4 md:grid-cols-3">
          {relatedServices.map((service) => (
            <article class="rounded-2xl border border-slate-700/60 bg-slate-950/40 p-5">
              <h3 class="text-lg font-semibold font-heading">{service.title}</h3>
              <p class="mt-3 text-sm text-muted dark:text-slate-400">{service.cardDescription}</p>
              <a
                href={getPermalink(`/services/${service.slug}`)}
                class="inline-block mt-4 text-primary dark:text-blue-400 hover:underline font-medium"
              >
                View service page
              </a>
            </article>
          ))}
        </div>
        <div class="mt-6 flex flex-wrap gap-4 text-sm">
          <a href={getPermalink('/services')} class="text-muted dark:text-slate-400 hover:text-primary transition ease-in duration-200">
            See all services
          </a>
          <a href={getPermalink('/#contact')} class="text-muted dark:text-slate-400 hover:text-primary transition ease-in duration-200">
            Book consultation
          </a>
        </div>
      </div>
    </section>
  ) : null
}

