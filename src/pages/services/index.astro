---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Note from '~/components/widgets/Note.astro';
import { coverageSummary, services } from '~/data/services';

const defaultContactNumber = '353874118332';
const contactNumber = (
  import.meta.env.PUBLIC_CONTACT_PHONE ||
  import.meta.env.PUBLIC_WHATSAPP_NUMBER ||
  defaultContactNumber
).replace(/\D/g, '');
const whatsappNumber = (import.meta.env.PUBLIC_WHATSAPP_NUMBER || contactNumber).replace(/\D/g, '');
const whatsappMessage = encodeURIComponent('Hi Unified Networks, I need help choosing the right network service.');
const phoneHref = `tel:+${contactNumber}`;
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

const metadata = {
  title: 'Network Services Dublin | Wi-Fi, Cabling, Starlink & More',
  ignoreTitleTemplate: true,
  description:
    'Choose the right Wi-Fi, cabling, Starlink, failover, or troubleshooting service in Dublin with a clear consultation-first process.',
};

const servicesHubUrl = 'https://unifiednetworks.ie/services';
const servicesHubSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Network Services Dublin',
  description: metadata.description,
  url: servicesHubUrl,
  hasPart: services.map((service, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: service.title,
    url: `https://unifiednetworks.ie/services/${service.slug}`,
  })),
};

const servicesBreadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://unifiednetworks.ie/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Services',
      item: servicesHubUrl,
    },
  ],
};

const serviceCards = services.map((service) => ({
  title: service.title,
  description: service.cardDescription,
  icon: service.icon,
  callToAction: {
    text: 'View service details',
    href: `/services/${service.slug}`,
  },
}));

const noteText = `Need help deciding? Tell us your town or Eircode and what is not working. We cover ${coverageSummary}. Call <a class="underline" href="${phoneHref}">+${contactNumber}</a> or <a class="underline" href="${whatsappHref}" target="_blank" rel="noopener noreferrer">chat on WhatsApp</a>.`;
const serviceSelectionSteps = [
  {
    title: 'Tell us what is not working',
    description: 'Slow rooms, dropouts, cabling questions, Starlink setup, event demand, or backup internet risk.',
    icon: 'tabler:message-circle',
  },
  {
    title: 'Share your town or Eircode',
    description:
      'We confirm coverage and whether the first step should be consultation, troubleshooting, survey, or direct installation.',
    icon: 'tabler:map-pin',
  },
  {
    title: 'Get the right service path',
    description:
      'If existing equipment can be reused, we say so. If a survey or larger redesign is needed, we scope that clearly.',
    icon: 'tabler:route',
  },
  {
    title: 'Move to implementation with clear scope',
    description: 'The goal is a better result, not sending you to the wrong service page and hoping it fits.',
    icon: 'tabler:clipboard-check',
  },
];
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(servicesHubSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(servicesBreadcrumbSchema)} />
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Book Consultation',
        href: '/#contact',
        icon: 'tabler:mail',
      },
      {
        text: 'Call Now',
        href: phoneHref,
        icon: 'tabler:phone-call',
      },
      {
        text: 'Chat on WhatsApp',
        href: whatsappHref,
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
    image={{
      src: '~/assets/images/hero2.png',
      alt: 'Network services for homes and businesses in Dublin and surrounding areas',
    }}
  >
    <Fragment slot="title">
      Choose The Right
      <br />
      Network Service In Dublin
    </Fragment>
    <Fragment slot="subtitle">
      Dedicated service pages for installation, optimization, cabling, Starlink, event connectivity, failover internet,
      and troubleshooting. If you are not sure which page fits, start with consultation and we will route you properly.
    </Fragment>
  </Hero>

  <Features
    id="services-list"
    tagline="All Services"
    title="Choose The Service You Need"
    subtitle="Each service has a dedicated page with clear scope, expected outcomes, and next steps."
    items={serviceCards}
  />

  <Steps
    id="service-selection"
    tagline="Selection Flow"
    title="How To Pick The Right Service Without Guessing"
    subtitle="Use this page as the commercial hub. The fastest path is to identify the actual problem, then move to the right service scope."
    items={serviceSelectionSteps}
  />

  <Note icon="tabler:info-square" title="Need A Recommendation?" description={noteText} />
</Layout>
