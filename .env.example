PUBLIC_WHATSAPP_NUMBER=353XXXXXXXXX

# Google Search Console API
# Use the Search Console property identifier, for example:
# GSC_PROPERTY_URL=sc-domain:unifiednetworks.ie
# or a URL-prefix property:
# GSC_PROPERTY_URL=https://unifiednetworks.ie/
GSC_PROPERTY_URL=
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
GSC_COUNTRY=
GSC_DEVICE=

# Shared Google service account credentials (optional fallback for GSC/GA4)
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# Google Analytics 4 Data API
# Use the numeric GA4 property id, for example 123456789
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# Chrome UX Report API
CRUX_API_KEY=
CRUX_ORIGIN=https://unifiednetworks.ie
CRUX_URL=
CRUX_FORM_FACTOR=
CRUX_HISTORY_PERIODS=10

# Bing Webmaster API
BING_WEBMASTER_API_KEY=
BING_SITE_URL=https://unifiednetworks.ie/

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_LANGUAGE=languageConstants/1000
# Ireland geo target constant example: 2108
GOOGLE_ADS_GEO_TARGETS=
GOOGLE_ADS_SITE=unifiednetworks.ie
